{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CER Consistency Schema",
  "description": "Schema for IFU/SSCP/labeling consistency assessment",
  "type": "object",
  "required": ["schema_name", "schema_version", "artifact_type", "project_id", "cer_run_id", "workflow_id", "step_id", "status", "created_at"],
  "properties": {
    "schema_name": {"type": "string", "const": "cer_consistency"},
    "schema_version": {"type": "string", "const": "v1"},
    "artifact_type": {"type": "string", "const": "ifu_sscp_labeling_consistency_report"},
    "project_id": {"type": "string"},
    "cer_run_id": {"type": "string"},
    "workflow_id": {"type": "string", "const": "cer_review_workflow_v1"},
    "step_id": {"type": "string", "const": "cer_ifu_sscp_label"},
    "produced_by_step": {"type": "string", "const": "cer_ifu_sscp_label"},
    "status": {"type": "string", "enum": ["scaffold_complete", "scaffold_stub", "draft", "validated", "real_analysis"]},
    "created_at": {"type": "string"},
    "source_traceability": {
      "type": "object",
      "properties": {
        "cer_docstruct_ref": {"type": "string"},
        "ifu_document_ref": {"type": "string"},
        "sscp_document_ref": {"type": "string"},
        "labeling_materials_ref": {"type": "array", "items": {"type": "string"}}
      }
    },
    "regulatory_anchor_id": {"type": "string", "enum": ["MDR_Annex_I", "MDR_Annex_VII_4.5.5", null]},
    "human_gate_required": {"type": "boolean", "const": false},
    "consistency_check": {
      "type": "object",
      "properties": {
        "ifu_cer_alignment": {"type": "string", "enum": ["aligned", "partial", "misaligned", "pending"]},
        "sscp_cer_alignment": {"type": "string", "enum": ["aligned", "partial", "misaligned", "pending"]},
        "labeling_cer_alignment": {"type": "string", "enum": ["aligned", "partial", "misaligned", "pending"]},
        "inconsistencies_found": {"type": "array", "items": {"type": "string"}}
      }
    },
    "note": {"type": "string"},
    "schema_gate_status": {"type": "string", "enum": ["scaffold_complete", "validated"]}
  }
}
