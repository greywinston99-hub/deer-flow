{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CER Closure Schema",
  "description": "Schema for closure bundle and follow-up handoff",
  "type": "object",
  "required": ["schema_name", "schema_version", "review_run_id", "round_id"],
  "properties": {
    "schema_name": {"type": "string", "const": "cer_closure"},
    "schema_version": {"type": "string", "const": "v1"},
    "review_run_id": {"type": "string"},
    "round_id": {"type": "string"},
    "closure_completed": {"type": "boolean"},
    "final_gate_status": {"type": "string", "enum": ["pass", "conditional_pass", "return_for_remediation"]},
    "overall_conclusion_ref": {"type": "string"},
    "deficiency_register_ref": {"type": "string"},
    "decision_ledger_entry_ref": {"type": "string"},
    "followup_required": {"type": "boolean"},
    "followup_items": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "item_id": {"type": "string"},
          "description_cn": {"type": "string"},
          "due_date": {"type": "string"},
          "owner": {"type": "string"},
          "reopen_trigger": {"type": "string"}
        }
      }
    },
    "milestone_refs": {"type": "array", "items": {"type": "string"}},
    "archived_artifacts": {"type": "array", "items": {"type": "string"}},
    "backflow_triggered": {"type": "boolean"},
    "notes_cn": {"type": "string"}
  }
}
