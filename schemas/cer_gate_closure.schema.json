{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deerflow.local/schemas/cer_gate_closure.schema.json",
  "title": "CER Gate Closure Report",
  "description": "Gate closure report for CER review - final decision and next actions.",
  "type": "object",
  "required": ["step_id", "final_decision", "human_decision", "provisional_gate", "closure_timestamp"],
  "properties": {
    "step_id": { "type": "string" },
    "final_decision": {
      "type": "string",
      "enum": ["pass", "conditional_pass", "rework_required"],
      "description": "Final gate decision following human review"
    },
    "human_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decision", "reviewer", "decision_date"],
      "properties": {
        "decision": {
          "type": "string",
          "enum": ["pass", "conditional_pass", "rework_required"]
        },
        "reviewer": { "type": "string" },
        "decision_date": { "type": "string" },
        "rationale": { "type": "string" },
        "linked_review_items": { "type": "array", "items": { "type": "string" } },
        "linked_capa_ids": { "type": "array", "items": { "type": "string" } },
        "simulated": { "type": "boolean" }
      }
    },
    "provisional_gate": {
      "type": "string",
      "enum": ["pass", "conditional_pass", "rework_required"]
    },
    "closure_timestamp": { "type": "string" },
    "next_action": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "description", "blocking"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["approved", "conditional_approval", "rework"]
        },
        "description": { "type": "string" },
        "blocking": { "type": "boolean" }
      }
    }
  }
}
