{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deerflow.ai/schemas/benchmark_derivation_trace.schema.json",
  "title": "Benchmark Derivation Trace",
  "description": "Per-endpoint SOTA benchmark derivation audit trail with source studies, comparability assessment, confidence, and acceptability rationale. BIGDP2026.6 Phase 2.",
  "type": "object",
  "required": ["schema_version", "generated_at", "endpoints"],
  "properties": {
    "schema_version": {
      "type": "string",
      "default": "1.0.0"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "generated_by": {
      "type": "string",
      "default": "_node_build_benchmark_trace"
    },
    "device_context": {
      "type": "object",
      "description": "Device context for benchmark interpretation.",
      "properties": {
        "device_name": { "type": "string" },
        "device_class": { "type": "string" },
        "intended_use": { "type": "string" },
        "clinical_domain": { "type": "string" }
      }
    },
    "endpoints": {
      "type": "array",
      "description": "Per-endpoint benchmark derivation trace records.",
      "items": {
        "type": "object",
        "required": ["endpoint_name", "endpoint_clinical_meaning", "source_studies", "benchmark_value_range", "directness", "confidence", "acceptability_rationale"],
        "properties": {
          "endpoint_name": {
            "type": "string",
            "description": "Standardized endpoint name."
          },
          "endpoint_clinical_meaning": {
            "type": "string",
            "description": "Clinical interpretation of what this endpoint measures."
          },
          "endpoint_type": {
            "type": "string",
            "enum": ["primary_efficacy", "primary_safety", "secondary_efficacy", "secondary_safety", "exploratory"],
            "description": "Endpoint type classification."
          },
          "source_studies": {
            "type": "array",
            "description": "PMID list of studies used to derive this benchmark.",
            "items": {
              "type": "object",
              "properties": {
                "pmid": { "type": "string" },
                "first_author": { "type": "string" },
                "year": { "type": "integer" },
                "study_design": { "type": "string" },
                "sample_size": { "type": "integer" },
                "relevance_weight": { "type": "number", "description": "0.0-1.0 relevance weight for this study." }
              }
            }
          },
          "benchmark_value_range": {
            "type": "object",
            "description": "Benchmark value or range derived from source studies.",
            "properties": {
              "value_type": { "type": "string", "enum": ["point_estimate", "range", "pooled_estimate", "narrative_only"] },
              "point_estimate": { "type": "number" },
              "ci_lower": { "type": "number" },
              "ci_upper": { "type": "number" },
              "range_min": { "type": "number" },
              "range_max": { "type": "number" },
              "unit": { "type": "string" },
              "derivation_method": { "type": "string", "description": "How was this benchmark derived (meta-analysis, weighted average, expert consensus, single study)?" }
            }
          },
          "population_comparability": {
            "type": "string",
            "enum": ["direct_match", "comparable", "partial_overlap", "different", "unknown"],
            "description": "How comparable is the source study population to the subject device target population?"
          },
          "population_comparability_rationale": {
            "type": "string"
          },
          "device_comparability": {
            "type": "string",
            "enum": ["same_device", "similar_device", "alternative_therapy", "different_device_class", "not_applicable"],
            "description": "How comparable is the source study device to the subject device?"
          },
          "device_comparability_rationale": {
            "type": "string"
          },
          "directness": {
            "type": "string",
            "enum": ["direct", "indirect", "fallback"],
            "description": "Directness of benchmark to subject device CER."
          },
          "confidence": {
            "type": "string",
            "enum": ["high", "medium", "low", "insufficient"],
            "description": "Confidence level in this benchmark."
          },
          "confidence_rationale": {
            "type": "string",
            "description": "Why this confidence level was assigned."
          },
          "acceptability_rationale": {
            "type": "string",
            "description": "WHY this benchmark is acceptable for CER use (or why not). Must be non-empty."
          },
          "alternatives_rejected_rationale": {
            "type": "string",
            "description": "What alternative benchmarks were considered and why they were rejected. Required when directness is 'fallback'."
          },
          "limitations": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Known limitations of this benchmark."
          }
        }
      }
    },
    "overall_assessment": {
      "type": "object",
      "properties": {
        "total_endpoints": { "type": "integer" },
        "direct_benchmarks": { "type": "integer" },
        "indirect_benchmarks": { "type": "integer" },
        "fallback_benchmarks": { "type": "integer" },
        "high_confidence_endpoints": { "type": "integer" },
        "medium_confidence_endpoints": { "type": "integer" },
        "low_confidence_endpoints": { "type": "integer" },
        "benchmark_adequacy": {
          "type": "string",
          "enum": ["adequate", "partially_adequate", "inadequate"],
          "description": "Overall benchmark adequacy for CER purposes."
        }
      }
    }
  }
}
