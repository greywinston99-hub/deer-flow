{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CER Benefit Risk Schema",
  "description": "Schema for benefit-risk assessment",
  "type": "object",
  "required": ["schema_name", "schema_version", "artifact_type", "project_id", "cer_run_id", "workflow_id", "step_id", "status", "created_at"],
  "properties": {
    "schema_name": {"type": "string", "const": "cer_benefit_risk"},
    "schema_version": {"type": "string", "const": "v1"},
    "artifact_type": {"type": "string", "const": "benefit_risk_report"},
    "project_id": {"type": "string"},
    "cer_run_id": {"type": "string"},
    "workflow_id": {"type": "string", "const": "cer_review_workflow_v1"},
    "step_id": {"type": "string", "const": "cer_clinical_evidence_panel"},
    "produced_by_step": {"type": "string", "const": "cer_clinical_evidence_panel"},
    "sub_assessment_id": {"type": "string", "const": "benefit_risk_assessment"},
    "status": {"type": "string", "enum": ["scaffold_complete", "scaffold_stub", "draft", "validated", "real_analysis"]},
    "created_at": {"type": "string"},
    "source_traceability": {
      "type": "object",
      "properties": {
        "benefit_claims_ref": {"type": "array", "items": {"type": "string"}},
        "risk_claims_ref": {"type": "array", "items": {"type": "string"}},
        "rmf_ref": {"type": "string"}
      }
    },
    "regulatory_anchor_id": {"type": "string", "enum": ["MDR_Annex_I_Chapter_I_1", "Annex_XIV_Part_A_5", null]},
    "human_gate_required": {"type": "boolean", "const": true},
    "requires_human_review": {"type": "boolean", "const": true},
    "human_gate_ref": {"type": "string", "const": "HG-06"},
    "human_gate_topic": {"type": "string", "const": "Benefit-risk acceptability"},
    "reviewer_question_id": {"type": "string", "const": "RQ-BR-001"},
    "dimension": {"type": "string", "const": "dim_8"},
    "benefit_risk_balance": {
      "type": "object",
      "properties": {
        "clinical_benefits_documented": {"type": "boolean"},
        "risks_documented": {"type": "boolean"},
        "benefit_risk_acceptable": {"type": "boolean"},
        "residual_uncertainties": {"type": "array", "items": {"type": "string"}}
      }
    },
    "no_final_decision_made": {"type": "boolean", "const": true},
    "layer3_prohibition": {"type": "boolean", "const": true},
    "note": {"type": "string"},
    "schema_gate_status": {"type": "string", "enum": ["scaffold_complete", "validated"]}
  }
}
