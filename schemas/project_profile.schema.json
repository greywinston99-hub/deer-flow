{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deerflow.local/schemas/project_profile.schema.json",
  "title": "Project Profile",
  "description": "Normalized profile for a single-project RMF review run.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "project_id",
    "project_name",
    "institution_profile",
    "review_scope",
    "primary_review_object",
    "input_package",
    "artifact_policy"
  ],
  "properties": {
    "project_id": {
      "type": "string",
      "minLength": 1
    },
    "project_name": {
      "type": "string",
      "minLength": 1
    },
    "institution_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "organization",
        "assessment_body",
        "profile_version"
      ],
      "properties": {
        "organization": {
          "type": "string"
        },
        "assessment_body": {
          "type": "string",
          "enum": [
            "BSI"
          ]
        },
        "profile_version": {
          "type": "string"
        }
      }
    },
    "review_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "review_language",
        "jurisdiction",
        "human_gate_required"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "single_project_serial_review"
          ]
        },
        "review_language": {
          "type": "string"
        },
        "jurisdiction": {
          "type": "string"
        },
        "human_gate_required": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "primary_review_object": {
      "type": "string",
      "enum": [
        "RMF"
      ]
    },
    "device_context": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "device_name": {
          "type": "string"
        },
        "device_family": {
          "type": "string"
        },
        "device_class": {
          "type": "string"
        },
        "intended_use": {
          "type": "string"
        },
        "market_stage": {
          "type": "string"
        }
      }
    },
    "input_package": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "root_path",
        "documents"
      ],
      "properties": {
        "root_path": {
          "type": "string"
        },
        "documents": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "doc_type",
              "path",
              "required_for_p0"
            ],
            "properties": {
              "doc_type": {
                "type": "string",
                "enum": [
                  "RMF",
                  "FMEA",
                  "Hazard_Analysis",
                  "CER",
                  "IFU",
                  "TD",
                  "PMS_PMCF",
                  "Other"
                ]
              },
              "label": {
                "type": "string"
              },
              "path": {
                "type": "string"
              },
              "required_for_p0": {
                "type": "boolean"
              },
              "source_ref": {
                "$ref": "#/$defs/sourceRef"
              }
            }
          }
        }
      }
    },
    "artifact_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_root",
        "persist_intermediate_artifacts"
      ],
      "properties": {
        "artifact_root": {
          "type": "string"
        },
        "persist_intermediate_artifacts": {
          "type": "boolean"
        },
        "final_outputs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "sourceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "document_id"
      ],
      "properties": {
        "document_id": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "section": {
          "type": "string"
        },
        "page": {
          "type": "integer",
          "minimum": 1
        },
        "line_span": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {
            "type": "integer",
            "minimum": 1
          }
        },
        "quote": {
          "type": "string"
        }
      }
    }
  }
}
