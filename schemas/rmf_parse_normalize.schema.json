{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deerflow.local/schemas/rmf_parse_normalize.schema.json",
  "title": "RMF Parse Normalize",
  "description": "RMF parse-normalize stage output — structured RMF / FMEA entities, cross-document references, and terminology map. Covers rmf_normalized.json / cross_doc_entities.json / term_map.json. fmea_normalized.json is validated separately by fmea_normalized.schema.json.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "run_id",
    "parsed_entities"
  ],
  "properties": {
    "schema_name": {
      "type": "string",
      "const": "rmf_parse_normalize"
    },
    "schema_version": {
      "type": "string",
      "const": "v1"
    },
    "run_id": {
      "type": "string"
    },
    "parsed_entities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "entity_id",
          "entity_type",
          "source_ref"
        ],
        "properties": {
          "entity_id": {
            "type": "string"
          },
          "entity_type": {
            "type": "string"
          },
          "value": {
            "type": [
              "string",
              "number",
              "object",
              "array",
              "null"
            ]
          },
          "source_ref": {
            "$ref": "#/$defs/sourceRef"
          },
          "ambiguous": {
            "type": "boolean"
          },
          "ambiguity_reason": {
            "type": "string"
          }
        }
      }
    },
    "normalization_decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "decision_id",
          "decision_type"
        ],
        "properties": {
          "decision_id": {
            "type": "string"
          },
          "decision_type": {
            "type": "string"
          },
          "raw_value": {
            "type": "string"
          },
          "normalized_value": {
            "type": "string"
          },
          "source_refs": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/sourceRef"
            }
          }
        }
      }
    },
    "cross_doc_entities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "entity_id"
        ],
        "properties": {
          "entity_id": {
            "type": "string"
          },
          "entity_kind": {
            "type": "string",
            "enum": [
              "risk",
              "control",
              "evidence",
              "warning",
              "contraindication",
              "indication",
              "other"
            ]
          },
          "linked_documents": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/sourceRef"
            }
          }
        }
      }
    },
    "term_map": {
      "type": "object",
      "additionalProperties": true
    },
    "findings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/finding"
      }
    },
    "source_traceability": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/sourceRef"
      }
    }
  },
  "$defs": {
    "sourceRef": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "document_id"
      ],
      "properties": {
        "document_id": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "section": {
          "type": "string"
        },
        "page": {
          "type": "integer",
          "minimum": 1
        },
        "quote": {
          "type": "string"
        }
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "finding_id",
        "severity",
        "description"
      ],
      "properties": {
        "finding_id": {
          "type": "string"
        },
        "severity": {
          "type": "string",
          "enum": [
            "blocking",
            "advisory",
            "informational"
          ]
        },
        "description": {
          "type": "string"
        },
        "source_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/sourceRef"
          }
        }
      }
    }
  }
}
