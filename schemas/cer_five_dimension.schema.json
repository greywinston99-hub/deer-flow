{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deerflow.local/schemas/cer_five_dimension.schema.json",
  "title": "CER Five-Dimension Review",
  "description": "Five-dimension assessment for CER review: STRUCT, LOGIC, EVID, CONS, BRR.",
  "type": "object",
  "required": ["step_id", "dimensions"],
  "properties": {
    "step_id": { "type": "string" },
    "prompt_contract_path": { "type": "string" },
    "prompt_contract_loaded": { "type": "boolean" },
    "document_ids": { "type": "array", "items": { "type": "string" } },
    "primary_review_object": { "type": "string", "const": "CER" },
    "dimensions": {
      "type": "object",
      "required": ["STRUCT", "LOGIC", "EVID", "CONS", "BRR"],
      "properties": {
        "STRUCT": {
          "type": "object",
          "properties": {
            "dimension_id": { "type": "string", "const": "STRUCT" },
            "label": { "type": "string" },
            "description": { "type": "string" },
            "status": { "type": "string", "enum": ["pass", "issues_detected", "needs_human_review"] },
            "present_sections": { "type": "array", "items": { "type": "string" } },
            "missing_sections": { "type": "array", "items": { "type": "string" } },
            "key_findings": { "type": "array", "items": { "type": "object" } },
            "evidence_refs": { "type": "array", "items": { "type": "object" } },
            "requires_human_review": { "type": "boolean" },
            "recommendation": { "type": "string" }
          }
        },
        "LOGIC": {
          "type": "object",
          "properties": {
            "dimension_id": { "type": "string", "const": "LOGIC" },
            "label": { "type": "string" },
            "description": { "type": "string" },
            "status": { "type": "string", "enum": ["pass", "issues_detected", "needs_human_review"] },
            "logical_flow": { "type": "array", "items": { "type": "string" } },
            "key_findings": { "type": "array", "items": { "type": "object" } },
            "evidence_refs": { "type": "array", "items": { "type": "object" } },
            "requires_human_review": { "type": "boolean" },
            "recommendation": { "type": "string" }
          }
        },
        "EVID": {
          "type": "object",
          "properties": {
            "dimension_id": { "type": "string", "const": "EVID" },
            "label": { "type": "string" },
            "description": { "type": "string" },
            "status": { "type": "string", "enum": ["pass", "issues_detected", "needs_human_review"] },
            "evidence_indicators": { "type": "array", "items": { "type": "object" } },
            "key_findings": { "type": "array", "items": { "type": "object" } },
            "evidence_refs": { "type": "array", "items": { "type": "object" } },
            "requires_human_review": { "type": "boolean" },
            "recommendation": { "type": "string" }
          }
        },
        "CONS": {
          "type": "object",
          "properties": {
            "dimension_id": { "type": "string", "const": "CONS" },
            "label": { "type": "string" },
            "description": { "type": "string" },
            "status": { "type": "string", "enum": ["pass", "issues_detected", "needs_human_review"] },
            "consistency_groups": { "type": "array", "items": { "type": "object" } },
            "key_findings": { "type": "array", "items": { "type": "object" } },
            "evidence_refs": { "type": "array", "items": { "type": "object" } },
            "requires_human_review": { "type": "boolean" },
            "recommendation": { "type": "string" }
          }
        },
        "BRR": {
          "type": "object",
          "properties": {
            "dimension_id": { "type": "string", "const": "BRR" },
            "label": { "type": "string" },
            "description": { "type": "string" },
            "status": { "type": "string", "enum": ["needs_human_review"] },
            "benefit_risk_section_present": { "type": "boolean" },
            "key_findings": { "type": "array", "items": { "type": "object" } },
            "evidence_refs": { "type": "array", "items": { "type": "object" } },
            "requires_human_review": { "type": "boolean", "const": true },
            "recommendation": { "type": "string" },
            "layer3_warning": { "type": "boolean", "const": true }
          }
        }
      }
    },
    "global_manual_review_needed": { "type": "boolean" },
    "source_binding_enforced": { "type": "boolean" },
    "upstream_summary": { "type": "object" }
  }
}
