{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CER SOTA Evidence Schema",
  "description": "Schema for cer-sota-evidence-agent output",
  "type": "object",
  "required": ["schema_name", "schema_version", "review_run_id", "round_id", "agent_name"],
  "properties": {
    "schema_name": {"type": "string", "const": "cer_sota_evidence"},
    "schema_version": {"type": "string", "const": "v2 — RCA A06_南驰 2026-06-04 (animal/cadaver exclusion + evidence hierarchy)"},
    "review_run_id": {"type": "string"},
    "round_id": {"type": "string"},
    "artifact_id": {"type": "string"},
    "artifact_type": {"type": "string", "const": "node_output"},
    "generated_by": {"type": "string", "const": "cer-sota-evidence-agent"},
    "generated_at": {"type": "string"},
    "input_refs": {"type": "array", "items": {"type": "string"}},
    "status": {"type": "string", "enum": ["draft", "final", "superseded", "archived"]},
    "summary_cn": {"type": "string"},
    "sota_findings": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "sota_item": {"type": "string"},
          "current_alternatives_covered": {"type": "boolean"},
          "device_relevant_benchmark": {"type": "boolean"},
          "evidence_basis": {"type": "array", "items": {"type": "string"}},
          "notes_cn": {"type": "string"}
        }
      }
    },
    "evidence_findings": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "finding_id": {"type": "string"},
          "study_ref": {"type": "string"},
          "human_or_animal": {"type": "string", "enum": ["human", "animal", "cadaver", "in_vitro"], "description": "P0 RCA A06_南驰 — animal/cadaver studies excluded from clinical evidence"},
          "study_design": {"type": "string"},
          "sample_size": {"type": "integer"},
          "evidence_level_oxford": {"type": "string", "enum": ["1a_sr_ma", "1b_rct", "2a_cohort", "2b_retrospective", "3_case_control", "4_case_series", "5_expert"], "description": "P0 RCA A06_南驰 — SOTA hierarchy: Meta/SR > RCT > Prospective > Retrospective > Case series"},
          "quality_tier": {"type": "string", "enum": ["high", "medium", "low", "very_low"]},
          "bias_handling": {"type": "string"},
          "endpoint_extraction": {"type": "string"},
          "synthesis_validity": {"type": "string"},
          "notes_cn": {"type": "string"}
        }
      }
    },
    "evidence_insufficiency_flags": {
      "type": "array",
      "items": {"type": "string"}
    },
    "finding_items": {"type": "array"},
    "evidence_basis": {"type": "array"},
    "confidence_level": {"type": "string", "enum": ["low", "medium", "high"]},
    "mandatory_human_review": {"type": "boolean"},
    "escalation_reason": {"type": "array", "items": {"type": "string"}},
    "suggested_next_action": {"type": "array", "items": {"type": "string"}},
    "artifact_paths": {"type": "array", "items": {"type": "string"}},
    "notes_cn": {"type