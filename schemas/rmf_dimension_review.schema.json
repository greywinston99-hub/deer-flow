{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deerflow.local/schemas/rmf_dimension_review.schema.json",
  "title": "RMF Dimension Review",
  "description": "RMF dimension review stage output — six-dimension reviewer agent produces COMP/CORR/ADEQ/TRAC/CONS/ACPT assessments in one call.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "step_id",
    "run_id",
    "dimensions"
  ],
  "properties": {
    "schema_name": {
      "type": "string",
      "const": "rmf_dimension_review"
    },
    "schema_version": {
      "type": "string",
      "const": "v1"
    },
    "step_id": {
      "type": "string"
    },
    "run_id": {
      "type": "string"
    },
    "thread_id": {
      "type": "string"
    },
    "dimensions": {
      "type": "object",
      "description": "Each of the six RMF review dimensions. Keys must be exactly COMP, CORR, ADEQ, TRAC, CONS, ACPT.",
      "properties": {
        "COMP": { "$ref": "#/$defs/dimensionEntry" },
        "CORR": { "$ref": "#/$defs/dimensionEntry" },
        "ADEQ": { "$ref": "#/$defs/dimensionEntry" },
        "TRAC": { "$ref": "#/$defs/dimensionEntry" },
        "CONS": { "$ref": "#/$defs/dimensionEntry" },
        "ACPT": { "$ref": "#/$defs/dimensionEntry" }
      },
      "additionalProperties": true
    },
    "overall_summary": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "status": { "type": "string" },
        "manual_review_needed": { "type": "boolean" },
        "rationale": { "type": "string" }
      }
    },
    "global_manual_review_needed": {
      "type": "boolean"
    },
    "source_traceability": {
      "type": "array",
      "items": { "$ref": "#/$defs/sourceRef" }
    }
  },
  "$defs": {
    "dimensionEntry": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "status"
      ],
      "properties": {
        "dimension_id": {
          "type": "string",
          "enum": ["COMP", "CORR", "ADEQ", "TRAC", "CONS", "ACPT"]
        },
        "label": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "supported",
            "weakly_evidenced",
            "issues_detected",
            "insufficient_evidence",
            "needs_human_review"
          ]
        },
        "human_attention_needed": {
          "type": "boolean"
        },
        "manual_review_needed": {
          "type": "boolean"
        },
        "evidence_hints": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidenceHint" }
        },
        "findings": {
          "type": "array",
          "items": { "$ref": "#/$defs/finding" }
        }
      }
    },
    "evidenceHint": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "check_key": { "type": "string" },
        "text": { "type": "string" },
        "source_ref": { "$ref": "#/$defs/sourceRef" }
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "finding_type",
        "detail"
      ],
      "properties": {
        "finding_id": { "type": "string" },
        "finding_type": { "type": "string" },
        "check_key": { "type": "string" },
        "severity": {
          "type": "string",
          "enum": [
            "blocking",
            "advisory",
            "informational",
            "high",
            "medium",
            "low"
          ]
        },
        "detail": { "type": "string" },
        "source_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/sourceRef" }
        }
      }
    },
    "sourceRef": {
      "type": "object",
      "additionalProperties": true,
      "required": ["document_id"],
      "properties": {
        "document_id": { "type": "string" },
        "path": { "type": "string" },
        "section": { "type": "string" },
        "page": { "type": "integer", "minimum": 1 },
        "quote": { "type": "string" }
      }
    }
  }
}
