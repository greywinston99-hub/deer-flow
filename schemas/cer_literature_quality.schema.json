{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deerflow.local/schemas/cer_literature_quality.schema.json",
  "title": "CER Literature Quality Assessment",
  "description": "Literature quality scoring for CER evidence review.",
  "type": "object",
  "required": ["assessment_id", "literature_quality_summary", "evidence_quality_distribution", "evidence_units"],
  "properties": {
    "assessment_id": { "type": "string" },
    "literature_quality_summary": {
      "type": "object",
      "properties": {
        "total_evidence_units": { "type": "integer" },
        "high_quality_count": { "type": "integer" },
        "medium_quality_count": { "type": "integer" },
        "low_quality_count": { "type": "integer" },
        "very_low_quality_count": { "type": "integer" },
        "insufficient_info_count": { "type": "integer" },
        "requires_human_review": { "type": "boolean" }
      }
    },
    "evidence_quality_distribution": {
      "type": "object",
      "properties": {
        "high": { "type": "array", "items": { "type": "string" } },
        "medium": { "type": "array", "items": { "type": "string" } },
        "low": { "type": "array", "items": { "type": "string" } },
        "very_low": { "type": "array", "items": { "type": "string" } },
        "insufficient_information": { "type": "array", "items": { "type": "string" } }
      }
    },
    "major_quality_concerns": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "concern_type": { "type": "string" },
          "affected_evidence_ids": { "type": "array", "items": { "type": "string" } },
          "severity": { "type": "string", "enum": ["high", "medium", "low"] },
          "description": { "type": "string" }
        }
      }
    },
    "evidence_units": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "evidence_unit_id": { "type": "string" },
          "source_document": { "type": "string" },
          "study_type": { "type": "string" },
          "quality_tier": {
            "type": "string",
            "enum": ["high", "medium", "low", "very_low", "insufficient_information"]
          },
          "quality_score": { "type": "number", "minimum": 0, "maximum": 10 },
          "strengths": { "type": "array", "items": { "type": "string" } },
          "weaknesses": { "type": "array", "items": { "type": "string" } },
          "requires_human_review": { "type": "boolean" },
          "source_ref": {
            "type": "object",
            "properties": {
              "document_id": { "type": "string" },
              "section": { "type": "string" },
              "line": { "type": "integer" }
            }
          }
        }
      }
    }
  }
}
