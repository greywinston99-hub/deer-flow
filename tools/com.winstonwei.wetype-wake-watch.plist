<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.winstonwei.wetype-wake-watch</string>

  <key>ProgramArguments</key>
  <array>
    <string>/Users/winstonwei/.local/bin/wetype-wake-watch.sh</string>
  </array>

  <key>RunAtLoad</key>
  <true/>

  <key>StartInterval</key>
  <integer>60</integer>

  <key>StandardOutPath</key>
  <string>/tmp/com.winstonwei.wetype-wake-watch.out</string>

  <key>StandardErrorPath</key>
  <string>/tmp/com.winstonwei.wetype-wake-watch.err</string>
</dict>
</plist>
