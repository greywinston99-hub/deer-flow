{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://deer-flow.example.com/schemas/rmf_agent_output.schema.json",
  "title": "RMF Agent Output Schema",
  "description": "Standard output schema for all RMF agent nodes",
  "type": "object",
  "required": ["node_id", "findings", "output_metadata"],
  "properties": {
    "node_id": {
      "type": "string",
      "enum": ["ORCH", "DOCSTRUCT", "L1", "COMP", "CORR", "ADEQ", "TRAC", "CONS", "ACPT", "QA", "PMS", "SYNTHESIS"],
      "description": "Unique identifier for the executing node"
    },
    "findings": {
      "type": "array",
      "description": "Array of findings generated by this node",
      "items": {
        "$ref": "#/definitions/finding"
      },
      "default": []
    },
    "output_data": {
      "type": "object",
      "description": "Node-specific output data beyond findings",
      "properties": {},
      "additionalProperties": true
    },
    "output_metadata": {
      "$ref": "#/definitions/output_metadata"
    },
    "_meta": {
      "$ref": "#/definitions/meta_trace"
    }
  },
  "definitions": {
    "finding": {
      "type": "object",
      "required": ["finding_id", "dimension", "finding_type", "severity", "description"],
      "properties": {
        "finding_id": {
          "type": "string",
          "pattern": "^[A-Z]+-\\d{3}$",
          "description": "Unique finding identifier (e.g., COMP-001)"
        },
        "dimension": {
          "type": "string",
          "enum": ["COMP", "CORR", "ADEQ", "TRAC", "CONS", "ACPT", "PMS", "L1", "QA"],
          "description": "RMF review dimension this finding belongs to"
        },
        "finding_type": {
          "type": "string",
          "description": "Categorization of the finding",
          "examples": [
            "coverage_gap",
            "insufficient_control",
            "method_inconsistency",
            "inherently_safe_failure",
            "orphan_risk",
            "terminology_inconsistency",
            "residual_risk_weak_rationale",
            "alarp_insufficient",
            "pms_plan_incomplete"
          ]
        },
        "severity": {
          "type": "string",
          "enum": ["critical", "major", "minor", "observation"],
          "description": "Severity level of the finding"
        },
        "description": {
          "type": "string",
          "minLength": 10,
          "description": "Human-readable description of the finding"
        },
        "source": {
          "type": "object",
          "description": "Source document and location of the finding",
          "properties": {
            "document": {
              "type": "string",
              "enum": ["RMF", "CER", "IFU", "FMEA", "NocoDB", "HumanGate"]
            },
            "section": {
              "type": "string"
            },
            "paragraph": {
              "type": "string"
            },
            "row": {
              "type": "string"
            }
          },
          "required": ["document"]
        },
        "recommendation": {
          "type": "string",
          "description": "Recommended action to address this finding"
        },
        "requires_human_review": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "output_metadata": {
      "type": "object",
      "required": ["node_version", "execution_time_ms", "model_profile"],
      "properties": {
        "node_version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+$",
          "description": "Version of the node specification"
        },
        "execution_time_ms": {
          "type": "integer",
          "minimum": 0,
          "description": "Execution time in milliseconds"
        },
        "model_profile": {
          "type": "string",
          "description": "Model profile used for execution",
          "examples": ["deterministic", "structured_extraction", "professional_reasoning", "high_stakes_reasoning", "qa_synthesis"]
        },
        "model_invoked": {
          "type": "boolean",
          "description": "Whether a live LLM was actually invoked"
        },
        "layer1_only": {
          "type": "boolean",
          "description": "For TRAC node: whether only Layer 1 (deterministic) was executed"
        },
        "pms_triggered": {
          "type": "boolean",
          "description": "For ACPT/CONS nodes: whether PMS Lane was triggered"
        }
      }
    },
    "meta_trace": {
      "type": "object",
      "description": "Tracing metadata for debugging and audit",
      "properties": {
        "trace_id": {
          "type": "string",
          "format": "uuid"
        },
        "parent_span_id": {
          "type": "string"
        },
        "span_id": {
          "type": "string"
        },
        "tags": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "start_time": {
          "type": "string",
          "format": "date-time"
        },
        "end_time": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}
